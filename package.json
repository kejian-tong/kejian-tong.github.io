{
  "name": "kejian-tong",
  "description": "Portfolio of Kejian Tong",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "next/core-web-vitals"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "export": "next build",
    "start": "serve out",
    "lint": "eslint src tests next.config.js playwright.config.ts tailwind.config.js postcss.config.js --max-warnings=0",
    "preview": "serve out",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:built": "playwright test",
    "test:e2e": "npm run build && npm run test:e2e:built",
    "test:e2e:headed": "npm run build && npm run test:e2e:built -- --headed",
    "test:e2e:ui": "npm run build && npm run test:e2e:built -- --ui",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "validate": "npm run type-check && npm run lint && npm run build"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.17",
    "next": "^15.5.18",
    "next-themes": "^0.3.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^4.12.0",
    "react-toastify": "^10.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.2.15",
    "autoprefixer": "^10.5.0",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.5.18",
    "postcss": "8.5.14",
    "serve": "14.2.6",
    "tailwindcss": "3.3.3",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
